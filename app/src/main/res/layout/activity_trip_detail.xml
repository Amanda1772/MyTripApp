<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trip Details"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/theme_text_main"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <EditText
        android:id="@+id/etDestination"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:hint="Destination"
        android:padding="12dp"
        android:background="@drawable/bg_chip"
        android:textColor="@color/theme_text_main"
        android:textColorHint="@color/theme_hint"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etStartDate"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:hint="Start Date"
        android:padding="12dp"
        android:background="@drawable/bg_chip"
        android:textColor="@color/theme_text_main"
        android:textColorHint="@color/theme_hint"
        app:layout_constraintTop_toBottomOf="@id/etDestination"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etEndDate"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:hint="End Date"
        android:padding="12dp"
        android:background="@drawable/bg_chip"
        android:textColor="@color/theme_text_main"
        android:textColorHint="@color/theme_hint"
        app:layout_constraintTop_toBottomOf="@id/etStartDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/etNotes"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="12dp"
        android:hint="Notes"
        android:padding="12dp"
        android:background="@drawable/bg_chip"
        android:textColor="@color/theme_text_main"
        android:textColorHint="@color/theme_hint"
        app:layout_constraintTop_toBottomOf="@id/etEndDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Switch
        android:id="@+id/switchPinned"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pin this trip"
        android:textColor="@color/theme_text_main"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/etNotes"
        app:layout_constraintStart_toStartOf="parent"/>

    <Button
        android:id="@+id/btnSaveTrip"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Save Trip"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_chip"
        android:textColor="@color/theme_text_main"
        app:layout_constraintTop_toBottomOf="@id/switchPinned"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnDeleteTrip"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Delete Trip"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_chip"
        android:textColor="@color/theme_text_main"
        app:layout_constraintTop_toBottomOf="@id/btnSaveTrip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>