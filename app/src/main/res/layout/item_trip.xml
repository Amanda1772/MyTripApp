<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp"
        android:background="@drawable/bg_gradient_card">

        <TextView
            android:id="@+id/tvDestination"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Destination"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/theme_text_main"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnPin"
            android:layout_marginEnd="10dp"/>

        <ImageButton
            android:id="@+id/btnPin"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@android:color/transparent"
            android:contentDescription="Pin"
            android:src="@android:drawable/btn_star_big_off"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvDates"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Dates"
            android:textColor="@color/theme_text_soft"
            app:layout_constraintTop_toBottomOf="@id/tvDestination"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="6dp"/>

        <TextView
            android:id="@+id/tvNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Notes"
            android:textColor="@color/theme_text_main"
            android:alpha="0.90"
            app:layout_constraintTop_toBottomOf="@id/tvDates"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_chip"
            android:text="Edit"
            android:textColor="@color/theme_text_main"
            android:gravity="center"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvNotes"
            app:layout_constraintEnd_toStartOf="@id/btnDelete"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_chip"
            android:text="Delete"
            android:textColor="@color/danger"
            android:gravity="center"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvNotes"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>